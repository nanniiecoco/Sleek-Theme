{% doc %}
  @prompt
    Section Description:
    This section features a large background image with editable text and buttons placed on top.
    On the same background, there is a small overlay image that remains in a fixed position (e.g., center left).
    The overlay image should automatically rotate through 1–4 uploaded images in sequence, creating a looping animation that continuously runs on top of the background image.
    The rotation should be smooth, using a fade transition between each image.
    
    Functional Requirements:
    
    Support background image uploads for both desktop and mobile versions.
    
    Allow up to 4 overlay images to be uploaded.
    
    The overlay should stay in the same position while switching between images automatically.
    
    Text and buttons over the background can be edited (content and links).
    
    The section layout should be fully responsive for both desktop and mobile.
    
    Example:
    A hero banner with a large background image.
    On the left side, a small image overlay cycles between 4 product shots.
    On the right side, editable text and CTA buttons are displayed.
    The overlay animation keeps looping while all other content stays static.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: 500px;
    overflow: hidden;
  }

  .ai-hero-banner__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-hero-banner__background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-banner__background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-banner__background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hero-banner__content-wrapper-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    min-height: 500px;
    padding: 60px 20px;
    max-width: {{ settings.page_width }}px;
    margin: 0 auto;
  }

  .ai-hero-banner__overlay-container-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.overlay_width }}px;
    height: {{ block.settings.overlay_height }}px;
    flex-shrink: 0;
  }

  .ai-hero-banner__overlay-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity {{ block.settings.transition_duration }}s ease-in-out;
  }

  .ai-hero-banner__overlay-image-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-hero-banner__overlay-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: {{ block.settings.overlay_border_radius }}px;
  }

  .ai-hero-banner__overlay-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.overlay_border_radius }}px;
  }

  .ai-hero-banner__overlay-placeholder-{{ ai_gen_id }} svg {
    width: 80%;
    height: 80%;
  }

  .ai-hero-banner__text-content-{{ ai_gen_id }} {
    flex: 1;
    padding: 0 40px;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-hero-banner__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 20px;
    color: {{ block.settings.text_color }};
  }

  .ai-hero-banner__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0 0 30px;
    color: {{ block.settings.text_color }};
  }

  .ai-hero-banner__buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
    {% if block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
  }

  .ai-hero-banner__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 15px 30px;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    transition: all 0.3s ease;
    min-width: 150px;
  }

  .ai-hero-banner__button-primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_primary_bg }};
    color: {{ block.settings.button_primary_color }};
    border: 2px solid {{ block.settings.button_primary_bg }};
  }

  .ai-hero-banner__button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_primary_hover_bg }};
    border-color: {{ block.settings.button_primary_hover_bg }};
    color: {{ block.settings.button_primary_hover_color }};
  }

  .ai-hero-banner__button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_secondary_bg }};
    color: {{ block.settings.button_secondary_color }};
    border: 2px solid {{ block.settings.button_secondary_border }};
  }

  .ai-hero-banner__button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_hover_bg }};
    border-color: {{ block.settings.button_secondary_hover_border }};
    color: {{ block.settings.button_secondary_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-banner__content-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 30px;
      min-height: 400px;
      padding: 40px 20px;
    }

    .ai-hero-banner__overlay-container-{{ ai_gen_id }} {
      width: {{ block.settings.overlay_width | times: 0.7 }}px;
      height: {{ block.settings.overlay_height | times: 0.7 }}px;
    }

    .ai-hero-banner__text-content-{{ ai_gen_id }} {
      padding: 0;
      text-align: center;
    }

    .ai-hero-banner__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-hero-banner__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.8 }}px;
    }

    .ai-hero-banner__buttons-{{ ai_gen_id }} {
      justify-content: center;
      flex-direction: column;
    }

    .ai-hero-banner__button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<hero-banner-{{ ai_gen_id }} class="ai-hero-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-banner__background-{{ ai_gen_id }}">
    {% if block.settings.background_image_desktop %}
      <picture>
        {% if block.settings.background_image_mobile %}
          <source media="(max-width: 749px)" srcset="{{ block.settings.background_image_mobile | image_url: width: 750 }}">
        {% endif %}
        <img
          src="{{ block.settings.background_image_desktop | image_url: width: 2000 }}"
          alt="{{ block.settings.background_image_desktop.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.background_image_desktop.width }}"
          height="{{ block.settings.background_image_desktop.height }}"
        >
      </picture>
    {% else %}
      <div class="ai-hero-banner__background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-hero-banner__content-wrapper-{{ ai_gen_id }}">
    {% if block.settings.overlay_position == 'left' %}
      <div class="ai-hero-banner__overlay-container-{{ ai_gen_id }}">
        {% for i in (1..4) %}
          {% liquid
            assign overlay_key = 'overlay_image_' | append: i
            assign overlay_image = block.settings[overlay_key]
          %}
          {% if overlay_image %}
            <div class="ai-hero-banner__overlay-image-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-overlay-index="{{ forloop.index }}">
              <img
                src="{{ overlay_image | image_url: width: 600 }}"
                alt="{{ overlay_image.alt | escape }}"
                loading="lazy"
                width="{{ overlay_image.width }}"
                height="{{ overlay_image.height }}"
              >
            </div>
          {% endif %}
        {% endfor %}
        {% unless block.settings.overlay_image_1 or block.settings.overlay_image_2 or block.settings.overlay_image_3 or block.settings.overlay_image_4 %}
          <div class="ai-hero-banner__overlay-placeholder-{{ ai_gen_id }}">
            {{ 'product-apparel-1' | placeholder_svg_tag }}
          </div>
        {% endunless %}
      </div>
    {% endif %}

    <div class="ai-hero-banner__text-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-hero-banner__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <div class="ai-hero-banner__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
      {% endif %}

      <div class="ai-hero-banner__buttons-{{ ai_gen_id }}">
        {% if block.settings.button_primary_label != blank %}
          <a
            href="{{ block.settings.button_primary_link }}"
            class="ai-hero-banner__button-{{ ai_gen_id }} ai-hero-banner__button-primary-{{ ai_gen_id }}"
          >
            {{ block.settings.button_primary_label }}
          </a>
        {% endif %}

        {% if block.settings.button_secondary_label != blank %}
          <a
            href="{{ block.settings.button_secondary_link }}"
            class="ai-hero-banner__button-{{ ai_gen_id }} ai-hero-banner__button-secondary-{{ ai_gen_id }}"
          >
            {{ block.settings.button_secondary_label }}
          </a>
        {% endif %}
      </div>
    </div>

    {% if block.settings.overlay_position == 'right' %}
      <div class="ai-hero-banner__overlay-container-{{ ai_gen_id }}">
        {% for i in (1..4) %}
          {% liquid
            assign overlay_key = 'overlay_image_' | append: i
            assign overlay_image = block.settings[overlay_key]
          %}
          {% if overlay_image %}
            <div class="ai-hero-banner__overlay-image-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-overlay-index="{{ forloop.index }}">
              <img
                src="{{ overlay_image | image_url: width: 600 }}"
                alt="{{ overlay_image.alt | escape }}"
                loading="lazy"
                width="{{ overlay_image.width }}"
                height="{{ overlay_image.height }}"
              >
            </div>
          {% endif %}
        {% endfor %}
        {% unless block.settings.overlay_image_1 or block.settings.overlay_image_2 or block.settings.overlay_image_3 or block.settings.overlay_image_4 %}
          <div class="ai-hero-banner__overlay-placeholder-{{ ai_gen_id }}">
            {{ 'product-apparel-1' | placeholder_svg_tag }}
          </div>
        {% endunless %}
      </div>
    {% endif %}
  </div>
</hero-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.overlayImages = this.querySelectorAll('.ai-hero-banner__overlay-image-{{ ai_gen_id }}');
        this.currentIndex = 0;
        this.intervalDuration = {{ block.settings.rotation_interval | times: 1000 }};
        this.intervalId = null;
      }

      connectedCallback() {
        if (this.overlayImages.length > 1) {
          this.startRotation();
        }
      }

      disconnectedCallback() {
        this.stopRotation();
      }

      startRotation() {
        this.intervalId = setInterval(() => {
          this.rotateImages();
        }, this.intervalDuration);
      }

      stopRotation() {
        if (this.intervalId) {
          clearInterval(this.intervalId);
          this.intervalId = null;
        }
      }

      rotateImages() {
        this.overlayImages[this.currentIndex].classList.remove('active');
        this.currentIndex = (this.currentIndex + 1) % this.overlayImages.length;
        this.overlayImages[this.currentIndex].classList.add('active');
      }
    }

    customElements.define('hero-banner-{{ ai_gen_id }}', HeroBanner{{ ai_gen_id }});
  })();
</script>

