{"sections":{"main":{"type":"main-page","disabled":true,"settings":{"padding_top":28,"padding_bottom":28}},"video_with_text_AEHdde":{"type":"video-with-text","blocks":{"heading_9F7Rjg":{"type":"heading","settings":{"heading":"NEW IDENTITY. NEW LOGO. NEW ERA.","heading_size":"hd3","heading_highlight_style":"none"}},"text_EGWjJd":{"type":"text","settings":{"text":"<p>C  P  S isn’t here to tell you who to become. It exists to give you the freedom to stay real, to grow without apology, and to show the world who you already are.<br\/><br\/>Across different ages, energies, and rhythms of life, everyone carries something personal — a story, a confidence, a way of dressing that feels true.<br\/><br\/>C  P  S is more than a mark. It’s an opening. A quiet permission to take up space, to be seen, to stand tall in your own way. <br\/><br\/>This is your space. Own it.<\/p>","text_size":"text-base"}}},"block_order":["heading_9F7Rjg","text_EGWjJd"],"name":"t:sections.video-with-text.name","settings":{"color_scheme":"scheme-7","video":"shopify:\/\/files\/videos\/Who we are Page_63380a17-87e0-4087-9b4a-e2dcdf47ed25.mp4","video_url":"","video_ratio":"1\/1","description":"","enable_video_autoplay":true,"enable_video_looping":true,"video_placement":"first","enable_parallax":false,"parallax_direction":"vertical","text_alignment":"left","padding_top":50,"padding_bottom":50,"show_section_divider":false,"divider_width":"fixed"}},"custom_content_wN3EKJ":{"type":"custom-content","custom_css":["[data-block-type=\"image\"] {max-width: 81.2rem; margin: 0 auto -9%;}",".rich-text__heading {max-width: 74rem; margin: 0 auto;}",".custom__block--text {max-width: 81.2rem; margin: 0 auto;}","@media (max-width: 767px) {[data-block-type=\"image\"] {margin-bottom: -14%; } .rich-text__heading {max-width: 33rem; }}"],"settings":{"container":"fixed","color_scheme":"","enable_sticky_column":false,"heading":"","heading_size":"h1","heading_highlight_style":"none","subheading":"","description":"","column_gap":"n