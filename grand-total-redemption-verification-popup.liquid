<script src="{{ 'grand-total-redemption-verification-popup.js' | asset_url }}" defer="defer"></script>
{{ 'grand-total-redemption-verification-popup.css' | asset_url | stylesheet_tag }}

<grand-total-redemption-verification-popup style="display: none;" class="grand-total-redemption-verification-popup">
    <div class="modal">
        <div class="modal-content">
            <button class="close">&times;</button>
            <h2>WARNING</h2>
            <div class="warning-content">
                <div class="column warning-icon">&#9888;</div>
                <div class="column">{{ 'point_redemption.redeem_less_than_total' | t }}</div>
            </div>
            <button class="ok-button">{{ 'point_redemption.ok' | t }}</button>
        </div>
    </div>
</grand-total-redemption-verification-popup>