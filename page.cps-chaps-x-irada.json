{"sections":{"main":{"type":"main-page","disabled":true,"settings":{"padding_top":28,"padding_bottom":28}},"custom_liquid_fy73UM":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n\n    \/* โครงสร้างหลัก *\/\n    #cps-scroll-scene {\n        position: relative;\n        width: 100%;\n        overflow: hidden;\n        margin: 0;\n        padding: 0;\n        background: transparent !important;\n        z-index: 1;\n    }\n\n    \/* กล่องภาพแต่ละช่วง *\/\n    #cps-scroll-scene .bg-frame {\n        position: relative;\n        width: 100%;\n        height: 100vh;\n        overflow: hidden;\n        cursor: pointer;\n        z-index: 0;\n    }\n\n    \/* รูปภาพแบบเต็มจอ *\/\n    #cps-scroll-scene .bg-frame img {\n        width: 100%;\n        height: 100%;\n        object-fit: cover;\n        display: block;\n        position: relative;\n        z-index: 1;\n    }\n\n    \/* โลโก้ลอยกลางล่าง *\/\n    #cps-scroll-scene .floating-logo {\n        position: fixed;\n        bottom: 35%;\n        left: 50%;\n        transform: translateX(-50%);\n        text-align: center;\n        z-index: 10;\n        transition: opacity 0.8s ease;\n    }\n\n    \/* โลโก้ Desktop *\/\n    #cps-scroll-scene .floating-logo img.desktop-logo {\n        width: 70vw;\n        max-width: 900px;\n        height: auto;\n        display: block;\n    }\n\n    \/* โลโก้ Mobile (ใหญ่ขึ้น) *\/\n    #cps-scroll-scene .floating-logo img.mobile-logo {\n        display: none;\n    }\n\n    \/* มือถือ *\/\n    @media (max-width: 767px) {\n        #cps-scroll-scene .bg-frame img.desktop-img {\n            display: none !important;\n        }\n\n        #cps-scroll-scene .bg-frame img.mobile-img {\n            display: block !important;\n        }\n\n        #cps-scroll-scene .floating-logo img.desktop-logo {\n            display: none !important;\n        }\n\n        #cps-scroll-scene .floating-logo img.mobile-logo {\n            display: block !important;\n            width: 90vw;\n            max-width: 520px;\n        }\n\n        #cps-scroll-scene .floating-logo {\n            bottom: 39%;\n        }\n    }\n\n    \/* Desktop *\/\n    @media (min-width: 768px) {\n        #cps-scroll-scene .bg-frame img.mobile-img {\n            display: none !important;\n        }\n    }\n<\/style>\n\n<div id=\"cps-scroll-scene\">\n    <!-- โลโก้ -->\n    <div class=\"floating-logo\" id=\"floatingLogo\">\n        <!-- Desktop Logo -->\n        <img class=\"desktop-logo\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/6170\/7912\/files\/CPS_IRADA_logo.png?v=1761729949\" alt=\"CPS CHAPS Logo Desktop\">\n        <!-- Mobile Logo -->\n        <img class=\"mobile-logo\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/6170\/7912\/files\/CPS_IRADA_Mobile.png?v=1762397501\" alt=\"CPS CHAPS Logo Mobile\">\n    <\/div>\n\n    <!-- ภาพแต่ละช่วง -->\n    <div class=\"bg-frame\" onclick=\"window.location.href='https:\/\/www.cpschaps.com\/products\/c25wgwe053';\">\n        <img class=\"desktop-img\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/6170\/7912\/files\/IRADA_1.jpg?v=1764227388\" alt=\"men-desktop\">\n        <img class=\"mobile-img\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/6170\/7912\/files\/IRADA_1_mobile.jpg?v=1764227636\" alt=\"men-mobile\">\n    <\/div>\n\n    <div class=\"bg-frame\" onclick=\"window.location.href='https:\/\/www.cpschaps.com\/products\/c25wgwe065';\">\n        <img class=\"desktop-img\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/6170\/7912\/files\/IRADA_2.jpg?v=1764227388\" alt=\"women-desktop\">\n        <img class=\"mobile-img\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/6170\/7912\/files\/IRADA_Mobile_-10.jpg?v=1764227636\" alt=\"women-mobile\">\n    <\/div>\n\n    <div class=\"bg-frame\" onclick=\"window.location.href='https:\/\/www.cpschaps.com\/products\/c25wgwe063';\">\n        <img class=\"desktop-img\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/6170\/7912\/files\/IRADA_3.jpg?v=1764227389\" alt=\"acc-desktop\">\n        <img class=\"mobile-img\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/6170\/7912\/files\/IRADA_Mobile_-11.jpg?v=1764227636\" alt=\"acc-mobile\">\n    <\/div>\n\n    <div class=\"bg-frame\" onclick=\"window.location.href='https:\/\/www.cpschaps.com\/products\/c25wgue057';\">\n        <img class=\"desktop-img\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/6170\/7912\/files\/IRADA_4.jpg?v=1764227388\" alt=\"acc-desktop\">\n        <img class=\"mobile-img\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/6170\/7912\/files\/IRADA_Mobile_-12.jpg?v=1764227636\" alt=\"acc-mobile\">\n    <\/div>\n    \n        <div class=\"bg-frame\" onclick=\"window.location.href='https:\/\/www.cpschaps.com\/products\/c25wgwe071';\">\n        <img class=\"desktop-img\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/6170\/7912\/files\/IRADA_5.jpg?v=1764227388\" alt=\"acc-desktop\">\n        <img class=\"mobile-img\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/6170\/7912\/files\/IRADA_Mobile_-13.jpg?v=1764227636\" alt=\"acc-mobile\">\n    <\/div>\n\n    <!-- อันสุดท้ายเท่านั้นที่มี last-frame -->\n    <div class=\"bg-frame last-frame\" onclick=\"window.location.href='https:\/\/www.cpschaps.com\/products\/c25wgwe077';\">\n        <img class=\"desktop-img\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/6170\/7912\/files\/IRADA_6.jpg?v=1764227387\" alt=\"acc-desktop\">\n        <img class=\"mobile-img\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/6170\/7912\/files\/IRADA_Mobile_-14.jpg?v=1764227635\" alt=\"acc-mobile\">\n    <\/div>\n<\/div>\n\n<script>\n(() => {\n    const logo = document.querySelector(\"#floatingLogo\");\n    const lastFrame = document.querySelector(\".last-frame\");\n\n    window.addEventListener(\"scroll\", () => {\n        const rect = lastFrame.getBoundingClientRect();\n        const windowHeight = window.innerHeight;\n\n        \/\/ fade-out โลโก้เมื่อครึ่งบนของภาพสุดท้ายเริ่มเข้าจอ\n        if (rect.top < windowHeight * 0.5) {\n            const progress = Math.max(0, 1 - rect.top \/ (windowHeight * 0.5));\n            logo.style.opacity = 1 - progress;\n        } else {\n            logo.style.opacity = 1;\n        }\n    });\n})();\n<\/script>","color_scheme":"","padding_top":0,"padding_bottom":0}},"rich_text_aFVYA9":{"type":"rich-text","blocks":{"heading_HcQaKW":{"type":"heading","settings":{"heading":"CPS | IRADA","heading_size":"h2","heading_highlight_style":"none"}},"text_B8yCN7":{"type":"text","settings":{"text":"<p>A fusion of CPS’s authentic, rebellious, cool and IRADA’s classic with a twists,<br\/>translating the raw energy and unfiltered spirit of Alternative Rock into fashion. It merges strength and edge with a sense<br\/>of freedom, dreaminess, and romance, creating pieces that feel both bold and effortlessly wearable in everyday life.<\/p>","text_size":"text-base"}}},"block_order":["heading_HcQaKW","text_B8yCN7"],"name":"t:sections.rich-text.presets.name","settings":{"color_scheme":"","content_alignment":"left","padding_top":50,"padding_bottom":0,"show_section_divider":false,"divider_width":"full"}},"rich_text_MVJyxf":{"type":"rich-text","blocks":{"text_ckziNr":{"type":"text","settings":{"text":"<p><em><strong>Rebellious<br\/>Classic with a twists<br\/>Edgy rock<br\/>Effortless<\/strong><\/em><\/p>","text_size":"text-lg"}}},"block_order":["text_ckziNr"],"name":"t:sections.rich-text.presets.name","settings":{"color_scheme":"","content_alignment":"left","padding_top":30,"padding_bottom":0,"show_section_divider":false,"divider_width":"full"}},"lookbook_cards_NWfjfC":{"type":"lookbook-cards","blocks":{"product_list_C8fJeY":{"type":"product_list","settings":{"product_list":["c25wgwe064"],"image":"shopify:\/\/shop_images\/Images_-15.jpg","heading":"Shop this look","heading_size":"h5"}},"product_list_pDPFXQ":{"type":"product_list","settings":{"product_list":["c25wgwe075"],"image":"shopify:\/\/shop_images