ontainer {\n  display: flex;\n  transition: transform 0.5s ease-in-out;\n}\n\n.card-images-item img {\n  width: 100%;\n  height: auto;\n  display: block;\n}\n@media screen and (min-width: 750px) {\n  .custom-slider-wrapper {\n    padding: 20px;\n  }\n  .card-images-container {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 20px;\n  }\n}\n\n@media screen and (max-width: 749px) {\n  .custom-slider-wrapper {\n    margin-top: -1px !important;\n\n    padding-bottom: 17px !important; \n    margin-left: calc(-1 * var(--gradient-container-radius, 0px)) !important;\n    margin-right: calc(-1 * var(--gradient-container-radius, 0px)) !important;\n  }\n\n  .card-images-container {\n    display: flex;\n    flex-wrap: nowrap;\n    overflow-x: auto;\n    scroll-snap-type: x mandatory;\n    scroll-behavior: smooth;\n    -webkit-overflow-scrolling: touch;\n    gap: 0;\n  }\n\n  .card-images-container::-webkit-scrollbar {\n    display: none;\n  }\n\n  .card-images-item {\n    flex: 0 0 100%;\n    scroll-snap-align: start;\n    padding: 0 10px !important; \n  }\n}\n<\/style>\n\n<script>\n  (function() {\n    const initCustomSlider = () => {\n      const slider = document.getElementById('CustomSlider');\n      if (!slider) return;\n\n      const autoSlide = () => {\n        if (window.innerWidth < 750) {\n          const itemWidth = slider.offsetWidth;\n          if (slider.scrollLeft + itemWidth >= slider.scrollWidth - 5) {\n            slider.scrollTo({ left: 0, behavior: 'smooth' });\n          } else {\n            slider.scrollBy({ left: itemWidth, behavior: 'smooth' });\n          }\n        }\n      };\n      setInterval(autoSlide, 3000);\n    };\n\n    if (document.readyState === 'complete') {\n      initCustomSlider();\n    } else {\n      window.addEventListener('load', initCustomSlider);\n    }\n  })();\n<\/script>","color_scheme":"","padding_top":0,"padding_bottom":24}},"card_images_yhA8VN":{"type":"card-images","blocks":{"image_card_ByQJQx":{"type":"ima